@model DriveWise.Models.DashboardViewModel
@{
    ViewBag.Title = "Logs";
}

<section class="page-section">
    <div class="section-header">
        <h1>Logs</h1>
        <p class="section-subtitle">System activity and event logs</p>
    </div>

    <div class="content-placeholder">
        <div class="placeholder-icon">
            <i class="fa-regular fa-circle-question"></i>
        </div>
        <h2>System Logs</h2>
        <p>View detailed system activity logs and debug information.</p>

        <div style="margin-top: 30px; text-align: left;">
            <p><strong>Log Types:</strong></p>
            <ul style="text-align: left; display: inline-block;">
                <li>System events and activities</li>
                <li>API request logs</li>
                <li>User action history</li>
                <li>Error and warning logs</li>
            </ul>
        </div>
    </div>
</section>

<style>
    .page-section {
        padding: 28px;
    }

    .section-header {
        margin-bottom: 28px;
    }

    .section-header h1 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-main);
        margin: 0 0 4px 0;
    }

    .section-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        margin: 0;
    }

    .content-placeholder {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 60px 20px;
        text-align: center;
    }

    .placeholder-icon {
        font-size: 48px;
        color: var(--yellow);
        margin-bottom: 16px;
    }

    .content-placeholder h2 {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-main);
        margin: 0 0 8px 0;
    }

    .content-placeholder p {
        color: var(--text-muted);
        margin: 0;
    }

    .content-placeholder ul {
        color: var(--text-main);
        list-style: none;
        padding-left: 0;
    }

    .content-placeholder ul li {
        padding: 6px 0;
        color: var(--text-muted);
    }

    .content-placeholder ul li:before {
        content: "✓ ";
        color: var(--yellow);
        font-weight: 700;
        margin-right: 8px;
    }
</style>
